{
  "name": "pulsar",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "packages/entry-point.js",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
