{
  "name": "@pulsar/main",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build",
    "dev": "bun scripts/watch.ts",
    "compile": "cross-env MODE=production bun run build && electron-builder build --config electron-builder.yml --dir --config.asar=false",
    "test:e2e": "bun run build && vitest run",
    "test:main": "vitest run -r packages/main --passWithNoTests",
    "postinstall": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/update-electron-vendors.js"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "cross-env": "7.0.3",
    "electron": "31.1.0",
    "typescript": "5.5.2",
    "vite": "5.3.3",
    "vitest": "1.6.0"
  },
  "dependencies": {
    "electron-updater": "6.2.1"
  }
}
